# Runpod environment variables for training/evaluation.
# `HUGGINGFACE_HUB_TOKEN` can be exported from `HF_TOKEN` in the shell.

# Hugging Face authentication
HF_TOKEN=
HF_MODEL_REPO_ID=

# Weights & Biases
WANDB_API_KEY=
WANDB_MODE=online

# Runpod cache paths
HF_HOME=/workspace/.cache/huggingface
TRANSFORMERS_CACHE=/workspace/.cache/huggingface/transformers
HF_DATASETS_CACHE=/workspace/.cache/huggingface/datasets

# Runtime toggles
TOKENIZERS_PARALLELISM=false
PYTHONUNBUFFERED=1
